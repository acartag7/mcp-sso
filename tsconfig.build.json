{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "noEmitOnError": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": false,
    "stripInternal": true
  },
  "include": ["src"],
  "exclude": ["test", "scripts", "**/*.test.ts", "**/*.d.ts"]
}
