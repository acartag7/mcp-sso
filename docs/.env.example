# mcp-sso example configuration. Copy to .env and fill in.
# Full reference: configuration.md (same directory).  NEVER commit a populated .env.
# Secrets (🔒) belong in a secret manager in production — this file is a template.

# --- Bridge (required for any real identity provider) ---
OAUTH_ISSUER=https://mcp.example.com
OAUTH_RESOURCE=https://mcp.example.com/mcp
# 🔒 HS256 consent secret — generate 32+ random chars (e.g. `openssl rand -base64 32`)
OAUTH_CONSENT_SIGNING_SECRET=replace-with-a-32-plus-char-random-secret
# 🔒 ES256 signing key as a JSON JWK (private). Generate one; do not reuse this placeholder.
OAUTH_SIGNING_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"REPLACE","x":"REPLACE","y":"REPLACE"}
# Optional bridge tuning (defaults shown):
# OAUTH_SCOPE_CATALOG=mcp:read,mcp:write
# OAUTH_DEFAULT_SCOPES=mcp:read
# OAUTH_ALLOWED_ORIGINS=https://mcp.example.com,https://claude.ai
# OAUTH_REDIRECT_ALLOWLIST=
# OAUTH_ALLOW_INSECURE_LOCALHOST=false   # dev only

# --- Identity provider: uncomment exactly ONE block ---

# Cloudflare Access
# CF_ACCESS_AUDIENCE=your-app-hex-aud-tag
# CF_ACCESS_CERTS_URL=https://<team>.cloudflareaccess.com/cdn-cgi/access/certs
# CF_ACCESS_ISSUER=https://<team>.cloudflareaccess.com
# CF_ACCESS_EMAIL_ALLOWLIST=

# Microsoft Entra ID
# ENTRA_TENANT_ID=<tenant-guid>
# ENTRA_CLIENT_ID=<app-client-id>
# ENTRA_CLIENT_SECRET=            # 🔒 omit for a public (PKCE) client
# ENTRA_REDIRECT_URI=https://mcp.example.com/oauth/callback
# ENTRA_ALLOWED_TENANT_IDS=
# ENTRA_SUBJECT_ALLOWLIST=

# Google
# GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=           # 🔒
# GOOGLE_REDIRECT_URI=https://mcp.example.com/oauth/callback
# GOOGLE_HOSTED_DOMAIN=
# GOOGLE_SUBJECT_ALLOWLIST=
# GOOGLE_ALLOW_EMAIL_ALLOWLIST=false

# Generic OIDC (Keycloak, Okta, Auth0, Dex, …)
# OIDC_ISSUER=https://idp.example.com/realms/main
# OIDC_CLIENT_ID=mcp-bridge
# OIDC_CLIENT_SECRET=             # 🔒 omit for a public (PKCE) client
# OIDC_REDIRECT_URI=https://mcp.example.com/oauth/callback
# OIDC_SCOPES=openid profile email
# OIDC_SUBJECT_ALLOWLIST=

# --- Runtime (optional) ---
# MCP_SSO_DIR=./.mcp-sso
# PORT=3000
# HOST=0.0.0.0

# --- api-key-gateway example only ---
# BACKEND_API_KEY=                # 🔒 the static credential injected for the backend MCP
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8788
