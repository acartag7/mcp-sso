{
  "name": "mcp-sso",
  "version": "0.2.2",
  "description": "OAuth 2.1 for remote MCP servers: a spec-correct resource-server verifier plus a small AS-lite bridge with a pluggable upstream identity provider.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.34.4",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-sso": "./dist/bin/init.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./store/memory": {
      "types": "./dist/store/memory.d.ts",
      "default": "./dist/store/memory.js"
    },
    "./store/sqlite": {
      "types": "./dist/store/sqlite.d.ts",
      "default": "./dist/store/sqlite.js"
    },
    "./store/mysql": {
      "types": "./dist/store/mysql.d.ts",
      "default": "./dist/store/mysql.js"
    },
    "./rate-limit/redis": {
      "types": "./dist/rate-limit/redis.d.ts",
      "default": "./dist/rate-limit/redis.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "default": "./dist/adapters/fastify.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "default": "./dist/adapters/express.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "default": "./dist/adapters/hono.js"
    },
    "./identity/cloudflare-access": {
      "types": "./dist/identity/cloudflare-access.d.ts",
      "default": "./dist/identity/cloudflare-access.js"
    },
    "./identity/entra": {
      "types": "./dist/identity/entra.d.ts",
      "default": "./dist/identity/entra.js"
    },
    "./identity/console-pairing": {
      "types": "./dist/identity/console-pairing.d.ts",
      "default": "./dist/identity/console-pairing.js"
    },
    "./identity/generic-oidc": {
      "types": "./dist/identity/generic-oidc.d.ts",
      "default": "./dist/identity/generic-oidc.js"
    },
    "./identity/google": {
      "types": "./dist/identity/google.d.ts",
      "default": "./dist/identity/google.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "test": "node --test --test-reporter=spec",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "check:lines": "node scripts/check-line-length.mjs"
  },
  "dependencies": {
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "express": "5.2.1",
    "fastify": "5.8.5",
    "hono": "4.12.26",
    "ioredis": "5.11.1",
    "mysql2": "3.22.5",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "fastify": ">=5",
    "express": ">=5",
    "hono": ">=4",
    "mysql2": ">=3",
    "ioredis": ">=5"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "oauth",
    "oauth2",
    "authorization",
    "resource-server",
    "identity",
    "cloudflare-access",
    "entra",
    "pkce",
    "jose",
    "dcr",
    "dynamic-client-registration",
    "sso",
    "gateway",
    "rfc9728",
    "entra-id"
  ],
  "homepage": "https://github.com/acartag7/mcp-sso",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acartag7/mcp-sso.git"
  },
  "bugs": {
    "url": "https://github.com/acartag7/mcp-sso/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
